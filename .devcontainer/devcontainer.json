{
  "name": "AI Agents Pro Workspace",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:20": {},
    "ghcr.io/devcontainers/features/rust:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-vscode.makefile-tools",
        "github.copilot",
        "github.copilot-chat",
        "github.github-vscode-theme",
        "huggingface.huggingface-vscode",
        "eamodio.gitlens",
        "ms-vscode.remote-explorer",
        "ms-vscode-remote.remote-containers",
        "ms-vscode.live-server",
        "ms-vscode.hexeditor",
        "ms-vscode.makefile-tools",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools",
        "redhat.vscode-yaml",
        "ms-vscode.json-editor",
        "tamasfe.even-better-toml",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit",
        "vadimcn.vscode-lldb",
        "rust-lang.rust-analyzer",
        "serayuzgur.crates",
        "ms-vscode.makefile-tools",
        "gruntfuggly.todo-tree",
        "wayou.vscode-todo-highlight",
        "alefragnani.bookmarks",
        "yzhang.markdown-all-in-one",
        "ritwickdey.LiveServer",
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "python.testing.pytestEnabled": true,
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.extraPaths": [
          "${workspaceFolder}/agents",
          "${workspaceFolder}/src",
          "${workspaceFolder}/notebooks"
        ],
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "[json]": {
          "editor.defaultFormatter": "vscode.json-language-features"
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "jupyter.kernels.trusted": [],
        "github.copilot.enable": {
          "*": true,
          "plaintext": false,
          "markdown": true
        },
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/**": true,
          "**/.pytest_cache/**": true,
          "**/__pycache__/**": true,
          "**/.*": true
        },
        "editor.rulers": [80, 100, 120],
        "editor.wordWrap": "on",
        "editor.trimAutoWhitespace": true
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "forwardPorts": [
    8000,
    8080,
    8888,
    5000,
    5432,
    6379,
    9000,
    3000,
    9090
  ],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI Server",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Web UI",
      "onAutoForward": "notify"
    },
    "8888": {
      "label": "Jupyter Lab",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "Flask App",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "3000": {
      "label": "Node Dev Server",
      "onAutoForward": "notify"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,readonly",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,readonly"
  ],
  "remoteUser": "vscode",
  "remoteEnv": {
    "HF_HOME": "/workspaces/.huggingface",
    "TORCH_HOME": "/workspaces/.cache/torch",
    "TRANSFORMERS_CACHE": "/workspaces/.cache/transformers",
    "PYTHONPATH": "/workspaces:/workspaces/agents:/workspaces/src"
  }
}
